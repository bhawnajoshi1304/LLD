@startuml
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam classAttributeIconSize 0

' =======================================================
' MODEL PACKAGE
' =======================================================
package "model" {
    class Building {
        - name: String
        - floors: List<Floor>
        - elevatorController: ElevatorController
        - hallPanels: List<HallPanel>
        - elevatorPanels: List<ElevatorPanel>
        + Building(String, int, int)
        + Building(String, int, List<Elevator>)
        + step(): void
        + addExternalRequest(int, Direction): void
        + getElevators(): List<Elevator>
        + setupObservers(List<Elevator>, String): void
        + setupPanels(List<Elevator>): void
    }

    class Floor {
        - id: int
        - hallPanels: List<HallPanel>
        + Floor(int, int, List<Elevator>)
    }

    class Elevator {
        - id: int
        - minFloor: int
        - maxFloor: int
        - currentFloor: int
        - state: ElevatorState
        - strategy: SchedulingStrategy
        - stateObservers: List<ElevatorObserver>
        - floorObservers: List<ElevatorObserver>
        + Elevator(int, int, SchedulingStrategy)
        + step(): void
        + addRequest(ElevatorRequest): void
        + addStateObserver(ElevatorObserver): void
        + addFloorObserver(ElevatorObserver): void
        + notifyFloorObservers(): void
        + notifyStateObservers(): void
        + hasPendingRequests(): boolean
        + getCurrentFloor(): int
        + getState(): ElevatorState
        + getStrategy(): SchedulingStrategy
        + setCurrentFloor(int): void
    }

    interface ElevatorRequest {
        + getFloor(): Integer
    }

    class ExternalRequest {
        - floor: int
        - direction: Direction
        + ExternalRequest(int, Direction)
        + getFloor(): Integer
        + getDirection(): Direction
    }

    class InternalRequest {
        - floor: int
        + InternalRequest(int)
        + getFloor(): Integer
    }

    enum Direction {
        IDLE
        UP
        DOWN
    }

    class ElevatorController {
        - elevators: List<Elevator>
        - strategy: SchedulingStrategy
        + ElevatorController(List<Elevator>, SchedulingStrategy)
        + step(): void
        + addRequest(ElevatorRequest): void
        + addRequestToSpecificElevator(int, ElevatorRequest): void
        + addObserver(ElevatorObserver): void
        + areAllElevatorsIdle(): boolean
    }
}

' =======================================================
' MEDIATOR PACKAGE
' =======================================================
package "mediator" {
    class Button {
        - action: Runnable
        + setOnPressListener(Runnable): void
        + press(): void
    }

    class HallPanel {
        - floor: int
        - elevator: Elevator
        - upButton: Button
        - downButton: Button
        + HallPanel(Elevator, int)
        + getFloor(): int
    }

    class ElevatorPanel {
        - elevator: Elevator
        - floorButtons: Map<Integer, Button>
        + ElevatorPanel(Elevator, int)
    }
}


' =======================================================
' STATE PACKAGE
' =======================================================
package "state" {
    interface ElevatorState {
        + onEnter(Elevator): void
        + getStateName(): String
        + step(Elevator): ElevatorState
    }

    class IdleState {
        - INSTANCE: IdleState
        + onEnter(Elevator): void
        + getStateName(): String
        + step(Elevator): ElevatorState
    }

    class MovingUpState {
        - INSTANCE: MovingUpState
        + onEnter(Elevator): void
        + getStateName(): String
        + step(Elevator): ElevatorState
    }

    class MovingDownState {
        - INSTANCE: MovingDownState
        + onEnter(Elevator): void
        + getStateName(): String
        + step(Elevator): ElevatorState
    }

    class StoppedState {
        - INSTANCE: StoppedState
        + onEnter(Elevator): void
        + getStateName(): String
        + step(Elevator): ElevatorState
    }
}

' =======================================================
' STRATEGY PACKAGE
' =======================================================
package "strategy" {
    interface SchedulingStrategy {
        + addRequest(ElevatorRequest, Elevator): void
        + getNextStop(Elevator): int
        + getNextFloor(Elevator): int
        + removeReachedFloor(int): void
        + hasRequests(): boolean
    }

    class FCFSSchedulingStrategy {
        - requests: Queue<Integer>
        + addRequest(ElevatorRequest, Elevator): void
        + getNextStop(Elevator): int
        + getNextFloor(Elevator): int
        + removeReachedFloor(int): void
        + hasRequests(): boolean
    }

    class ScanSchedulingStrategy {
        - upRequests: Queue<Integer>
        - downRequests: Queue<Integer>
        + addRequest(ElevatorRequest, Elevator): void
        + getNextStop(Elevator): int
        + getNextFloor(Elevator): int
        + removeReachedFloor(int): void
        + hasRequests(): boolean
    }

    class LookSchedulingStrategy {
        - upRequests: Queue<Integer>
        - downRequests: Queue<Integer>
        + addRequest(ElevatorRequest, Elevator): void
        + getNextStop(Elevator): int
        + getNextFloor(Elevator): int
        + removeReachedFloor(int): void
        + hasRequests(): boolean
    }
}

' =======================================================
' OBSERVER PACKAGE
' =======================================================
package "observer" {
    interface ElevatorObserver {
        + onElevatorFloorChanged(int): void
        + onElevatorStateChanged(ElevatorState): void
    }

    class ElevatorDisplay {
        - currentFloor: int
        - currentState: String
        + onElevatorFloorChanged(int): void
        + onElevatorStateChanged(ElevatorState): void
        - displayCombined(): void
    }

    class ElevatorLogger {
        - elevatorId: int
        - buildingName: String
        - logWriter: PrintWriter
        - globalStepCounter: int
        + ElevatorLogger(int, String)
        + onElevatorFloorChanged(int): void
        + onElevatorStateChanged(ElevatorState): void
        + close(): void
        + incrementStepCounter(): void
    }
}

' Relationships
Building *-- "*" Floor
Building *-- ElevatorController
Building *-- "*" HallPanel
Building *-- "*" ElevatorPanel
ElevatorController *-- "*" Elevator
Elevator o-- ElevatorState
Elevator o-- SchedulingStrategy
Elevator *-- "*" ElevatorObserver
HallPanel *-- "2" Button
ElevatorPanel *-- "*" Button
HallPanel --> Elevator
ElevatorPanel --> Elevator

' Cross-package relationships
HallPanel ..> model.Elevator
ElevatorPanel ..> model.Elevator
Button ..> model.Elevator

' Inheritance
ExternalRequest ..|> ElevatorRequest
InternalRequest ..|> ElevatorRequest
ElevatorState <|.. IdleState
ElevatorState <|.. MovingUpState
ElevatorState <|.. MovingDownState
ElevatorState <|.. StoppedState
SchedulingStrategy <|.. FCFSSchedulingStrategy
SchedulingStrategy <|.. ScanSchedulingStrategy
SchedulingStrategy <|.. LookSchedulingStrategy
ElevatorObserver <|.. ElevatorDisplay
ElevatorObserver <|.. ElevatorLogger

@enduml
