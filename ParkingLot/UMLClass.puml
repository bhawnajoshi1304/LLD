@startuml
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam classAttributeIconSize 0

enum ParkingSpotType {
        SMALL
        BIG
        LARGE
    }

    enum VehicleType {
        MOTORBIKE
        CAR
        TRUCK
    }

interface AllocationStrategy{
        + supportsPark(vehicleType: VehicleType, spotType: ParkingSpotType): boolean
        + getPreferredSpotOrder(vehicleType: VehicleType): List<ParkingSpotType>
    }

    interface FeeStrategy{
        + calculateFee(type: ParkingSpotType, duration: long): double
    }

    interface PaymentStrategy{
        + processPayment(amount: double): void
    }

    class FlexibleAllocationStrategy <<Strategy>> {
        + supportsPark(vehicleType: VehicleType, spotType: ParkingSpotType): boolean
        + getPreferredSpotOrder(vehicleType: VehicleType): List<ParkingSpotType>
    }

    class ThreadSafeParkingStrategy <<Strategy>> {
        - vehicleToSpotMapping: Map<VehicleType, List<ParkingSpotType>>
        - spotAllocationCounts: Map<String, AtomicInteger>
        - strategyLock: ReadWriteLock
        + supportsPark(vehicleType: VehicleType, spotType: ParkingSpotType): boolean
        + getPreferredSpotOrder(vehicleType: VehicleType): List<ParkingSpotType>
        + recordSpotAllocation(spotType: ParkingSpotType): void
        + getAllocationStatistics(): Map<String, Integer>
        + updateVehicleMapping(vehicleType: VehicleType, spotTypes: List<ParkingSpotType>): void
        + findOptimalSpot(floors: List<ParkingFloor>, vehicleType: VehicleType): ParkingSpot
        + resetStatistics(): void
    }

    class BasicFeeStrategy <<Strategy>> {
        + calculateFee(type: ParkingSpotType, duration: long): double
    }

    class ThreadSafePaymentStrategy <<Strategy>> {
        - hourlyRates: Map<ParkingSpotType, Double>
        - transactionHistory: Map<String, PaymentTransaction>
        - rateLock: ReadWriteLock
        - transactionCounter: AtomicInteger
        - totalRevenue: AtomicLong
        + calculateFee(type: ParkingSpotType, durationMinutes: long): double
        + calculateSessionFee(session: ParkingSession): double
        + updateHourlyRate(spotType: ParkingSpotType, newRate: double): void
        + getCurrentRates(): Map<ParkingSpotType, Double>
        + getTransactionHistory(): Map<String, PaymentTransaction>
        + getTotalRevenue(): double
        + getRevenueBySpotType(): Map<ParkingSpotType, Double>
        + getTransactionStatistics(): TransactionStatistics
    }

    class CardPayment <<Strategy>> {
        + processPayment(amount: double): void
    }

    class CashPayment <<Strategy>> {
        + processPayment(amount: double): void
    }

    class UPIPayment <<Strategy>> {
        + processPayment(amount: double): void
    }

    AllocationStrategy <|.. FlexibleAllocationStrategy
    AllocationStrategy <|.. ThreadSafeParkingStrategy
    FeeStrategy <|.. BasicFeeStrategy
    FeeStrategy <|.. ThreadSafePaymentStrategy
    PaymentStrategy <|.. CardPayment
    PaymentStrategy <|.. CashPayment
    PaymentStrategy <|.. UPIPayment

interface ParkingObserver{
        + onVehicleEntry(session: ParkingSession): void
        + onVehicleExit(session: ParkingSession): void
    }

    class DisplayBoard <<Observer>> {
        + onVehicleEntry(session: ParkingSession): void
        + onVehicleExit(session: ParkingSession): void
    }

    class LoggingSystem <<Observer>> {
        - logFilePath: String
        + LoggingSystem(logFilePath: String)
        - log(message: String): void
        + onVehicleEntry(session: ParkingSession): void
        + onVehicleExit(session: ParkingSession): void
    }

    class UserPaymentSystem <<Observer>> {
        - feeStrategy: FeeStrategy
        + UserPaymentSystem(feeStrategy: FeeStrategy)
        + onVehicleEntry(session: ParkingSession): void
        + onVehicleExit(session: ParkingSession): void
    }

    ParkingObserver <|.. DisplayBoard
    ParkingObserver <|.. LoggingSystem
    ParkingObserver <|.. UserPaymentSystem

interface ParkingSpotState{
        + canParkVehicle(spot: ParkingSpot, vehicle: Vehicle, strategy: AllocationStrategy): boolean
        + parkVehicle(spot: ParkingSpot, vehicle: Vehicle): void
        + exitVehicle(spot: ParkingSpot): void
        + isOccupied(): boolean
    }

    class AvailableState <<State>> {
        + canParkVehicle(spot: ParkingSpot, vehicle: Vehicle, strategy: AllocationStrategy): boolean
        + parkVehicle(spot: ParkingSpot, vehicle: Vehicle): void
        + exitVehicle(spot: ParkingSpot): void
        + isOccupied(): boolean
    }

    class OccupiedState <<State>> {
        + canParkVehicle(spot: ParkingSpot, vehicle: Vehicle, strategy: AllocationStrategy): boolean
        + parkVehicle(spot: ParkingSpot, vehicle: Vehicle): void
        + exitVehicle(spot: ParkingSpot): void
        + isOccupied(): boolean
    }

    class OutOfServiceState <<State>> {
        + canParkVehicle(spot: ParkingSpot, vehicle: Vehicle, strategy: AllocationStrategy): boolean
        + parkVehicle(spot: ParkingSpot, vehicle: Vehicle): void
        + exitVehicle(spot: ParkingSpot): void
        + isOccupied(): boolean
    }

    ParkingSpotState <|.. AvailableState
    ParkingSpotState <|.. OccupiedState
    ParkingSpotState <|.. OutOfServiceState

class ParkingSpot {
         - spotNumber: String
         - vehicle: Vehicle
         - spotType: ParkingSpotType
         - occupiedAt: LocalDateTime
         - state: ParkingSpotState
         + ParkingSpot(spotNumber: String, spotType: ParkingSpotType)
         + canParkVehicle(vehicle: Vehicle, strategy: AllocationStrategy): boolean
         + parkVehicle(vehicle: Vehicle): void
         + exitVehicle(): void
         + isOccupied(): boolean
         + getSpotId(): String
         + getSpotType(): ParkingSpotType
         + getState(): ParkingSpotState
         + setState(state: ParkingSpotState): void
         + setVehicle(vehicle: Vehicle): void
         + setOccupiedAt(occupiedAt: LocalDateTime): void
     }

class Vehicle <<immutable>> {
        - numberPlate: String
        - type: VehicleType
        ~ Vehicle(numberPlate: String, type: VehicleType)
        + getVehicleType(): VehicleType
        + getNumberPlate(): String
    }

class ParkingLotManager {
        - exitObservers: List<ParkingObserver>
        - entryObservers: List<ParkingObserver>
        + ParkingLotManager()
        + registerExit(obs: ParkingObserver): void
        + registerEntry(obs: ParkingObserver): void
        + notifyExit(parkingSession: ParkingSession): void
        + notifyEntry(parkingSession: ParkingSession): void
    }

class ParkingSpotFactory <<Factory>> {
        + create(spotId: String, type: ParkingSpotType): ParkingSpot {static}
    }

class VehicleFactory <<Factory>> {
        + create(type: VehicleType, licenceNumber: String): Vehicle {static}
    }

class ParkingLotManagerFactory <<Factory>> {
        + create(feeStrategy: FeeStrategy): ParkingLotManager {static}
    }

    ParkingSpotFactory ..> ParkingSpot
    VehicleFactory ..> Vehicle
    ParkingLotManagerFactory ..> ParkingLotManager

class ParkingFloor {
        - floorMap: Map<ParkingSpotType, List<ParkingSpot>>
        - floorNumber: int
        + ParkingFloor(floorConfig: Map<ParkingSpotType, Integer>, floor: int)
        + getParkingSpotById(id: String): ParkingSpot
        + getAvailableSpotOfType(type: ParkingSpotType): ParkingSpot
        + printFloorDetails(): void
        + getFloorNumber(): int
    }

class ParkingSession {
        - user: User
        - spot: ParkingSpot
        - entryTime: LocalDateTime
        - exitTime: LocalDateTime
        + ParkingSession(user: User, spot: ParkingSpot)
        + endSession(): void
        + calculateDurationMinutes(): long
        + getUser(): User
        + getSpot(): ParkingSpot
        + toString(): String
    }

class ParkingLot <<Singleton>> {
     - floors: List<ParkingFloor>
     - activeSessions: Map<String, ParkingSession>
     - lock: Lock
     - allocationStrategy: AllocationStrategy
     - parkingLotManager: ParkingLotManager
     - lot: ParkingLot {static}
     - ParkingLot(allocationStrategy: AllocationStrategy,parkingLotManager: ParkingLotManager, floorCount: int, floorMap: List<Map<ParkingSpotType, Integer>>)
     + createInstance(feeStrategy: FeeStrategy, allocationStrategy: AllocationStrategy, floorCount: int, floorMap: List<Map<ParkingSpotType, Integer>>): ParkingLot {static}
     + getInstance(): ParkingLot {static}
     - findAvailableSlot(vehicleType: VehicleType): ParkingSpot
     + park(user: User): void
     + exit(user: User): void
 }

class User {
        - vehicle: Vehicle
        - paymentStrategy: PaymentStrategy
        + User(type: VehicleType, vehicleNumber: String, paymentStrategy: PaymentStrategy)
        + pay(amount: double): void
        + getVehicle(): Vehicle
    }

' RELATIONSHIPS
ParkingFloor *-- ParkingSpot
ParkingFloor ..> ParkingSpotFactory

ParkingLot *-- ParkingFloor
ParkingLot --> ParkingSession
ParkingLot --> ParkingSpot
ParkingLot --> ParkingLotManager
ParkingLot o-- AllocationStrategy
ParkingLot ..> FeeStrategy

User *-- Vehicle
User --> PaymentStrategy

ParkingSession --> User
ParkingSession --> ParkingSpot

ParkingObserver --> ParkingSession
ParkingLotManager --> ParkingObserver

UserPaymentSystem --> FeeStrategy

ParkingSpot o-- ParkingSpotState
ParkingSpotState --> ParkingSpot

@enduml' Trigger workflow update
