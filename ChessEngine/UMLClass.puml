@startuml
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam classAttributeIconSize 0

class Board {
        - cells: Cell[][]
        - pieces: Set<Piece>
        + getCell(Position): Cell
        + getActivePieces(Color): List<Piece>
        + makeMove(Move): boolean
        + isValidMove(Move): boolean
    }

    class Cell {
        - position: Position
        - piece: Piece
        + isEmpty(): boolean
        + getPiece(): Piece
        + setPiece(Piece): void
        + removePiece(): void
    }

    class Position {
        - row: int
        - col: int
        + <<Create>> Position(int, int)
        + getRow(): int
        + getCol(): int
    }

    class Move {
        - from: Position
        - to: Position
        - piece: Piece
        + <<Create>> Move(Position, Position, Piece)
    }

    class Player {
        - name: String
        - color: Color
        - isHuman: boolean
        + <<Create>> Player(String, Color, boolean)
    }

    class Engine {
        - board: Board
        - whitePlayer: Player
        - blackPlayer: Player
        - currentPlayer: Player
        - state: GameState
        + startGame(): void
        + makeMove(Move): boolean
        + switchTurn(): void
        + setState(GameState): void
    }

    class ThreadSafeEngine {
        - gameStatus: AtomicReference<GameState>
        - gameActive: AtomicBoolean
        - gameLock: ReentrantReadWriteLock
        - moveValidationExecutor: ExecutorService
        - gameStateExecutor: ExecutorService
        - moveHistory: Map<String, Move>
        - moveCounter: AtomicInteger
        - kingInCheck: AtomicBoolean
        - kingPositions: Map<Color, Position>
        - checkValidationCache: Map<String, Boolean>
        + startGame(String, String, PlayerStrategy, PlayerStrategy): void
        + play(): void
        + validateAndExecuteMove(Position, Position): boolean
        + wouldLeaveKingInCheck(Position, Position): boolean
        + updateGameState(): void
        + isCheckmate(Color): boolean
        + isStalemate(Color): boolean
        + shutdown(): void
    }

    enum Color {
        WHITE
        BLACK
    }

    enum Status {
        PLAYING
        STARTED
        WON
        LOST
        ACTIVE
    }

interface MoveStrategy {
        + isValidMove(Board, Move): boolean
    }

    class PawnMoveStrategy {
        + isValidMove(Board, Move): boolean
    }

    class KnightMoveStrategy {
        + isValidMove(Board, Move): boolean
    }

    class BishopMoveStrategy {
        + isValidMove(Board, Move): boolean
    }

    class RookMoveStrategy {
        + isValidMove(Board, Move): boolean
    }

    class QueenMoveStrategy {
        + isValidMove(Board, Move): boolean
    }

    class KingMoveStrategy {
        + isValidMove(Board, Move): boolean
    }

    class Piece {
        - type: PieceType
        - color: Color
        - moveStrategy: MoveStrategy
        + canMove(Board, Move): boolean
    }

    class PieceFactory {
        + createPiece(PieceType, Color): Piece
    }

    interface PlayerStrategy {
        + getMove(Board): Move
    }

    class HumanPlayerStrategy {
        + getMove(Board): Move
    }

    class ComputerPlayerStrategy {
        + getMove(Board): Move
    }

    MoveStrategy <|.. PawnMoveStrategy
    MoveStrategy <|.. KnightMoveStrategy
    MoveStrategy <|.. BishopMoveStrategy
    MoveStrategy <|.. RookMoveStrategy
    MoveStrategy <|.. QueenMoveStrategy
    MoveStrategy <|.. KingMoveStrategy

    PlayerStrategy <|.. HumanPlayerStrategy
    PlayerStrategy <|.. ComputerPlayerStrategy

interface GameState {
        + onEnter(Engine): void
        + onExit(Engine): void
        + canMove(Engine, Board): boolean
        + isGameOver(): boolean
        + getStateName(): String
    }

    class ActiveState {
        + onEnter(Engine): void
        + canMove(Engine, Board): boolean
        + isGameOver(): boolean
    }

    class CheckState {
        - kingInCheck: Color
        + onEnter(Engine): void
        + canMove(Engine, Board): boolean
        + isGameOver(): boolean
    }

    class CheckmateState {
        - winner: Color
        + onEnter(Engine): void
        + canMove(Engine, Board): boolean
        + isGameOver(): boolean
    }

    class StalemateState {
        + onEnter(Engine): void
        + canMove(Engine, Board): boolean
        + isGameOver(): boolean
    }

    GameState <|.. ActiveState
    GameState <|.. CheckState
    GameState <|.. CheckmateState
    GameState <|.. StalemateState

' Relationships
Board *-- Cell
Cell --> Piece
Cell --> Position
Engine *-- Board
Engine *-- Player
Engine o-- GameState
Move --> Position
ThreadSafeEngine --|> Engine

Piece --> MoveStrategy
PieceFactory ..> Piece
PieceFactory ..> Color

Player --> Color
Engine --> GameState
Engine --> PlayerStrategy

@enduml
' Trigger workflow update
